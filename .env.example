# Скопіюйте в .env локально. На PythonAnywhere — Web → Environment variables.

# flask | bot | rag
PROJECT_TYPE=flask

# Шлях до клону на PA (зазвичай /home/ВАШ_ЛОГІН/csc_template)
REPO_PATH=/home/yourusername/csc_template

# Секрет для GitHub webhook (однаковий у GitHub і тут)
GITHUB_WEBHOOK_SECRET=change-me-to-long-random-string

# Reload після деплою (шлях з Web → WSGI configuration file)
PA_WSGI_FILE=/var/www/yourusername_pythonanywhere_com_wsgi.py

# Або reload через API (Account → API token)
PA_USERNAME=yourusername
PA_API_TOKEN=
PA_API_HOST=www.pythonanywhere.com
PA_DOMAIN=yourusername.pythonanywhere.com

# bot
TELEGRAM_BOT_TOKEN=
PA_ALWAYS_ON_TASK_ID=

# rag
OPENAI_API_KEY=
